@model AgroStockAI.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    <div class="mb-4">
        <h1 class="fw-bold">Dashboard AgroStockAI</h1>
        <p class="text-muted">
            Panel general del sistema de gestión de inventario agropecuario.
        </p>
    </div>

    <div class="alert alert-success shadow-sm">
        <strong>Estado del sistema:</strong> Aplicación conectada correctamente a la base de datos y usuario autenticado.
    </div>

    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <h5 class="text-muted">Productos</h5>
                    <h2 class="fw-bold">@Model.TotalProductos</h2>
                    <p class="text-muted mb-0">Productos registrados</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <h5 class="text-muted">Categorías</h5>
                    <h2 class="fw-bold">@Model.TotalCategorias</h2>
                    <p class="text-muted mb-0">Clasificaciones creadas</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <h5 class="text-muted">Movimientos</h5>
                    <h2 class="fw-bold">@Model.TotalMovimientos</h2>
                    <p class="text-muted mb-0">Entradas y salidas</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <h5 class="text-muted">Alertas Activas</h5>
                    <h2 class="fw-bold">@Model.TotalAlertasActivas</h2>
                    <p class="text-muted mb-0">Alertas pendientes</p>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white">
            <h4 class="mb-0">Últimos Movimientos</h4>
        </div>

        <div class="card-body">
            @if (Model.UltimosMovimientos.Any())
            {
                <table class="table table-hover table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Producto</th>
                            <th>Tipo Movimiento</th>
                            <th>Cantidad</th>
                            <th>Fecha</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var movimiento in Model.UltimosMovimientos)
                        {
                            <tr>
                                <td>@movimiento.Producto?.Nombre</td>
                                <td>@movimiento.TipoMovimiento</td>
                                <td>@movimiento.Cantidad</td>
                                <td>@movimiento.Fecha.ToShortDateString()</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">No hay movimientos registrados.</p>
            }
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h4>Bienvenido al Sistema AgroStockAI</h4>
            <ul class="mb-0">
                <li>Este panel le permite visualizar de forma rápida el estado general del inventario, 
                    la cantidad de productos registrados, categorías, movimientos realizados y alertas activas del sistema.</li>
            </ul>
        </div>
    </div>

</div>